# .gitignore
# ============================================================
# GitHub for AI Builders — Root Repository
# ============================================================
# This file covers the entire monorepo:
#   - docs/          (Astro/Starlight site)
#   - starter-project/python/   (FastAPI)
#   - starter-project/nodejs/   (Express)
#   - .github/       (CI workflows)
#
# MODULE 00 TEACHING REFERENCE:
# This is the root .gitignore — it applies to every file in
# the repository. Each starter-project variant also has its
# own .gitignore for language-specific patterns.
# ============================================================

# ── Secrets & Environment ─────────────────────────────────
# CRITICAL: Never commit .env files — they contain API keys,
# database URLs, and other credentials.
# The .env.example files ARE committed (placeholder names only).
.env
.env.*
!.env.example
!**/.env.example

# ── Node.js / npm ─────────────────────────────────────────
# Covers docs/ (Astro) and starter-project/nodejs/
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn/
.pnp.*
package-lock.json.bak

# ── Astro / Starlight Build Output ────────────────────────
# The built site — generated by `npm run build` in docs/
docs/dist/
docs/.astro/
_site/

# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
.venv/
venv/
env/
ENV/
.virtualenv/

# Python packaging
*.egg-info/
*.egg
dist/
build/
wheels/

# Type checking and linting caches
.mypy_cache/
.ruff_cache/
.pytype/

# ── Testing & Coverage ────────────────────────────────────
# Python
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/

# JavaScript
coverage/
.nyc_output/
junit.xml

# ── AI / ML Specific ──────────────────────────────────────
# Local model weight files — too large for Git and may contain
# licensed or proprietary model data. Never commit these.
*.gguf
*.bin
*.pt
*.pth
*.safetensors
*.ckpt
models/
checkpoints/

# ── Docker ────────────────────────────────────────────────
# Local Docker build context artifacts
.dockerignore.local

# ── IDE & Editor ──────────────────────────────────────────
# JetBrains (PyCharm, WebStorm, etc.)
.idea/
*.iml
*.iws

# VS Code — workspace settings are personal, but shared
# settings in .vscode/settings.json can be committed
# if the team agrees. Exclude user-specific files.
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json

# Vim
*.swp
*.swo
*~

# Emacs
\#*\#
.\#*

# ── Operating System ──────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
.fuse_hidden*
.Trash-*

# ── Logs ──────────────────────────────────────────────────
*.log
logs/
/tmp/

# ── Certificates & Keys ───────────────────────────────────
# Private keys and certificates should never be committed
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx

# ── Jupyter ───────────────────────────────────────────────
# Notebook outputs can contain sensitive data or model outputs
.ipynb_checkpoints/
*.ipynb

# ── MkDocs (not used, but guard against accidental use) ───
site/