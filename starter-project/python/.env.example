# .env.example
# ============================================================
# Environment Variables — A2A Starter Project (Python)
# ============================================================
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# NEVER commit .env — it is listed in .gitignore.
# This file (.env.example) IS safe to commit because it
# contains placeholder names only, not real values.
# ============================================================

# ── Ports ─────────────────────────────────────────────────
# Each service runs on its own port. Change these if you have
# conflicts with other services on your machine.
ORCHESTRATOR_PORT=8000
ECHO_AGENT_PORT=8001
SEARCH_AGENT_PORT=8002

# ── Agent URLs ────────────────────────────────────────────
# The Orchestrator uses these to route requests to agents.
# In a Codespace these are localhost; in Docker use container names.
ECHO_AGENT_URL=http://localhost:8001
SEARCH_AGENT_URL=http://localhost:8002

# ── API Keys ──────────────────────────────────────────────
# The Search Agent uses the OpenAI API for demonstrations
# in later modules. The Echo Agent does NOT need this.
# Leave blank for Modules 00–04; fill in for Module 05+.
OPENAI_API_KEY=your-openai-api-key-here

# ── Environment ───────────────────────────────────────────
# Set to "development" locally, "test" during CI, "production"
# when deploying via the release workflow.
APP_ENV=development
